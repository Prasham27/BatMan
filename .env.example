# Required for Alfred (the AI assistant). Server-side only — never NEXT_PUBLIC_.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional — lifts public GitHub limit from 60/hr to 5000/hr per IP.
GITHUB_TOKEN=

# Where the deployed site lives. Used in sitemap.xml + robots.txt.
NEXT_PUBLIC_SITE_URL=

# Required for the /channel contact form to actually send mail.
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Email address that receives messages submitted via /channel.
# On the Resend free tier (no domain verified), this must be the address you
# signed up with. To send from a custom domain, verify it in the Resend dashboard.
CONTACT_TO_EMAIL=
